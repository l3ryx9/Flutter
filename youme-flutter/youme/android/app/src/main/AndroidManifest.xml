<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════════════════════════════════════════════════════════
         PERMISSIONS — Only what is strictly necessary
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Camera / Media (for chat attachments) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- Legacy storage for Android < 13 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Audio recording (voice messages) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Location (live location feature) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Vibration (notification feedback) -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Wake lock (foreground notification) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         APPLICATION
         ════════════════════════════════════════════════════════════════════ -->
    <application
        android:label="YouMe"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"

        <!-- SECURITY: disable backup to prevent data extraction via adb -->
        android:allowBackup="false"
        android:fullBackupContent="false"
        tools:replace="android:allowBackup"

        <!-- SECURITY: disable debug mode in release -->
        android:debuggable="false"

        <!-- SECURITY: disable cleartext traffic (HTTP) -->
        android:usesCleartextTraffic="false"

        <!-- SECURITY: network security configuration (certificate pinning, no HTTP) -->
        android:networkSecurityConfig="@xml/network_security_config"

        <!-- SECURITY: restrict app from appearing in recents when backgrounded (screenshot prevention optional)
        android:excludeFromRecents="true" -->

        <!-- Hardware acceleration -->
        android:hardwareAccelerated="true">

        <!-- ── Main Activity ──────────────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            <!-- SECURITY: prevent screenshots in recent apps preview -->
            android:excludeFromRecents="false">

            <!-- App entry point -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Flutter deep link support -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
        </activity>

        <!-- ── Flutter deferred components ───────────────────────────────── -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />

        <!-- ── Firebase Messaging ─────────────────────────────────────────── -->
        <service
            android:name="com.google.firebase.messaging.FirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- ── Google Maps API Key (injected via --dart-define, not hardcoded) ── -->
        <!-- Note: MAPS_API_KEY is set via build process, not hardcoded here -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

    </application>

</manifest>
