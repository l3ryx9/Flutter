# ─── YouMe V2 — Variables d'environnement ────────────────────────────────────
# Copiez ce fichier vers .env et remplissez les valeurs.
# Toutes les variables EXPO_PUBLIC_* sont exposées côté client (bundle JS).
# Ne jamais committer le fichier .env réel en Git.

# ── Supabase (obligatoire) ────────────────────────────────────────────────────
# Trouvez ces valeurs dans : Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon_ici

# ── Google Maps (Android uniquement, optionnel) ───────────────────────────────
# Requis uniquement si vous utilisez les cartes en temps réel.
# Créez une clé dans : console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY_ANDROID=votre_cle_google_maps_android
